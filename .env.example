# Server-side API origin used by NextAuth and route handlers.
API_URL=http://localhost:5163

# Browser API base. Keep this as `/api/backend` to use the same-origin proxy.
NEXT_PUBLIC_API_URL=/api/backend

# Backend origin for SignalR WebSockets (same host/port as API_URL).
NEXT_PUBLIC_BACKEND_ORIGIN=http://localhost:5163

# Auth.js secret. Use the same value for both for compatibility.
AUTH_SECRET=change-this-to-a-32-plus-character-secret
NEXTAUTH_SECRET=change-this-to-a-32-plus-character-secret

# Public app URL for callbacks and absolute redirects.
NEXTAUTH_URL=http://localhost:3000

# Optional: enable bundle analyzer for `npm run build`.
# ANALYZE=false
